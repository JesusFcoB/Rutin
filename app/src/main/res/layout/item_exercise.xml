<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/surface"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Number badge -->
        <TextView
            android:id="@+id/tvNumber"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="1"
            android:textSize="15sp"
            android:textColor="@color/accent"
            android:background="@drawable/badge_background"
            android:fontFamily="@font/barlow_condensed_bold"
            android:layout_marginEnd="14dp"/>

        <!-- Name + sets/reps -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Press de banca con barra"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/barlow_condensed_semibold"/>

            <TextView
                android:id="@+id/tvSetsReps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4 series · 8-10 reps"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/barlow_condensed_semibold"/>

        </LinearLayout>

        <!-- Check button -->
        <CheckBox
            android:id="@+id/checkDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@drawable/checkbox_selector"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>